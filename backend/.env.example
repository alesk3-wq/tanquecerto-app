# development (padrão) ou production (serve o build do frontend, CORS desligado)
# NODE_ENV=production

PORT=3000
# Em produção atrás do "tailscale serve", descomente para não expor a porta na LAN:
# HOST=127.0.0.1

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=tanquecerto

# Gere uma chave forte com: openssl rand -base64 48
JWT_SECRET=coloque_uma_chave_secreta_longa_aqui
JWT_EXPIRES_IN=7d

# URL pública onde o app é acessado — usada só pra montar os links dos
# e-mails de confirmação/recuperação de senha (ex: https://octa.eco.br).
# Independente de qual proxy/host resolve HTTPS — troca só isso ao mudar
# de servidor/domínio, sem tocar em código.
APP_BASE_URL=http://localhost:5173

# Envio de e-mail transacional via Resend (https://resend.com). Sem a chave,
# o app loga o e-mail no console em vez de enviar de verdade (dá pra testar
# sem conta no Resend). EMAIL_FROM precisa ser um remetente/domínio validado
# no painel do Resend antes de enviar pra qualquer destinatário.
# RESEND_API_KEY=re_xxx
# EMAIL_FROM="TanqueCerto <naoresponda@seudominio.com>"
